# Copy to .env.local and fill in from your Supabase project's
# Project Settings -> API page. Only the publishable (anon-equivalent) key
# ever belongs on the frontend — never put the secret/service-role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx
